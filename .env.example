# Vetriver — copy to .env and fill in. Never commit .env.

# Razorpay dashboard -> Settings -> API Keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Razorpay dashboard -> Settings -> Webhooks. Set endpoint to
# https://vetriver.in/api/webhook and subscribe to payment.captured + payment.failed
RAZORPAY_WEBHOOK_SECRET=

# Admin dashboard bearer token. Generate one:  openssl rand -hex 32
ADMIN_TOKEN=

# Optional. Defaults to 3000.
PORT=3000
